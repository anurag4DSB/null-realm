# ============================================================
# Null Realm — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All vars below are loaded by nullrealm/config.py (Pydantic Settings).
# Defaults work for local Kind/docker-compose dev.
# ============================================================

# --- LLM API Keys ---

# Google Gemini — get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Anthropic Claude — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Database (PostgreSQL + pgvector) ---
# Default works with docker-compose / Kind local setup
DATABASE_URL=postgresql+asyncpg://nullrealm:nullrealm@localhost:5432/nullrealm

# --- NATS (messaging) ---
NATS_URL=nats://localhost:4222

# --- Langfuse (LLM observability) ---
# Self-hosted Langfuse runs in docker-compose / Kind
# Keys are auto-generated on first Langfuse start; update after setup
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://localhost:3001

# --- Jaeger / OpenTelemetry (distributed tracing) ---
JAEGER_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- LiteLLM Proxy ---
LITELLM_URL=http://localhost:4000/v1

# --- Service Settings ---
ENVIRONMENT=local
LOG_LEVEL=info
